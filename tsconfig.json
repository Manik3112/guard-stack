{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "rootDir": "./src",
    "lib": ["ES2020"],
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "dist", "tests", "examples", "main"]
}
