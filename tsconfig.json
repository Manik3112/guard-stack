{
  "compilerOptions": {
    "module": "commonjs",
    "strict": true,
    "target": "es2017",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./main",
    "baseUrl": "./main",
    "lib": ["es2020"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./main/**/*"],
  "exclude": ["node_modules", "dist"]
}
