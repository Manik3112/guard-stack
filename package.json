{
  "name": "guard-stack",
  "version": "0.0.1",
  "description": "TypeScript library with hexagonal architecture—core business logic separated from frame adapters for easy upgrades, testability, and long-term scalability.",
  "author": "Manik Rastogi",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Manik3112/ts-base-starter.git"
  },
  "bugs": {
    "url": "https://github.com/Manik3112/ts-base-starter/issues"
  },
  "homepage": "https://github.com/Manik3112/ts-base-starter#readme",
  "keywords": [
    "typescript",
    "hexagonal-architecture",
    "ports-and-adapters",
    "library"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "moment": "^2.29.4",
    "mongodb": "^4.8.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/node": "^18.0.4",
    "@types/uuid": "^8.3.4",
    "typescript": "^4.7.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
